{
  "name": "coffeewithme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema=prisma/schema.prod.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:push:prod": "prisma db push --schema=prisma/schema.prod.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=prisma/schema.prod.prisma",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.14.0",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.2.10",
    "leaflet": "^1.9.4",
    "next": "^14.2.3",
    "next-auth": "^4.24.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "^14.2.3",
    "postcss": "^8",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5"
  }
}
