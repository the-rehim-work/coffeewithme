# ─── LOCAL DEV (.env.local) ─────────────────────────────────────────
# DATABASE_URL="file:./dev.db"
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="random-secret"
# GOOGLE_CLIENT_ID="..."           # redirect: http://localhost:3000/api/auth/callback/google
# GOOGLE_CLIENT_SECRET="..."

# ─── VERCEL PRODUCTION (set in Vercel dashboard) ─────────────────────
# DATABASE_URL="postgresql://neondb_owner:...@....neon.tech/neondb?sslmode=require"
# NEXTAUTH_URL="https://coffeewithme.vercel.app"
# NEXTAUTH_SECRET="strong-random-secret"
# GOOGLE_CLIENT_ID="..."           # redirect: https://coffeewithme.vercel.app/api/auth/callback/google
# GOOGLE_CLIENT_SECRET="..."
